# Copy this file to .env and fill local values. Do not commit .env.

# Facebook publishing
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# OpenAI ASR/title tools, optional
OPENAI_API_KEY=
OPENAI_ASR_MODEL=gpt-4o-mini-transcribe
OPENAI_MODEL=gpt-4.1-mini

# Local paths
PIPELINE_DB_PATH=data/pipeline.sqlite3
DOWNLOAD_OUTPUT_DIR=data/downloads
ASR_CHUNKS_DIR=data/asr_chunks
TRANSCRIPTS_DIR=data/transcripts

# Browser automation
FACEBOOK_BROWSER=chrome
PLAYWRIGHT_HEADLESS=0

# Douyin integration
# Default expected sibling folder: ../douyin_downloader/data/app.db
DOUYIN_DB_PATH=..\douyin_downloader\data\app.db